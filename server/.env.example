# Copy this file to server/.env and fill in real values.
# NEVER commit server/.env to git.

PORT=3000

# MySQL / Azure
DB_HOST=your-db-host.mysql.database.azure.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=astro_data
DB_SSL=require
# DB_SSL_CA_PATH=/path/to/ca.pem

# n8n
N8N_CHAT_URL=https://your-n8n-host/webhook/your-webhook
N8N_SECRET=your-hmac-secret
# N8N_SPEECH_URL=

# Astrologer API (RapidAPI)
ASTRO_API_BASE=https://astrologer.p.rapidapi.com
ASTRO_API_KEY=your-rapidapi-key
ASTRO_LANG=EN
ASTRO_THEME=dark
ASTRO_ZODIAC=Tropic
ASTRO_HOUSE_SYSTEM=P
ASTRO_PERSPECTIVE=Apparent Geocentric

# Geo
NOMINATIM_BASE=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=your-email@example.com
# GEONAMES_USERNAME=your-geonames-username

# Supabase (service role — keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS — comma-separated list of allowed web origins
# Leave empty or set to your deployed web URL(s)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
